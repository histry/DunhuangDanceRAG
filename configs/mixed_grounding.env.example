# Opt-in configuration for the paper-one mixed-curvature grounder.
# Copy or source this file only after building a strict paired dataset.
export V46_53_GROUNDER_ARCHITECTURE=mixed
export V46_53_GROUNDER_PAIRED_DATASET="/absolute/path/to/paired_grounding.npz"
export V46_53_MIXED_EPOCHS=120
export V46_53_GROUNDER_BATCH=96
export V46_53_MIXED_HIDDEN=192
export V46_53_MIXED_LORENTZ_DIM=16
export V46_53_MIXED_SPHERE_DIM=96
export V46_53_MIXED_COV_EPS=0.0001
export V46_53_MIXED_HIERARCHY_W=0.20
export V46_53_MIXED_GAUSSIAN_W=0.25
export V46_53_MIXED_CONTROL_W=0.10
export V46_53_MIXED_UNCERTAINTY_W=0.05
export V46_53_MIXED_SOURCE_W=0.05
export V46_53_MIXED_METRIC_BALANCE_W=0.01
