# Paper-two V46.55 Fisher-Rao / discrete Graph-SB routing profile.
# Source configs/research.env first, then override strict experiment settings.
export V46_55_ROUTE_SOLVER=fisher_rao_graph_sb
export V46_55_FR_TEMPERATURE=0.65
export V46_55_FR_MARGINAL_STRENGTH=0.90
export V46_55_SB_EPSILON=0.35
export V46_55_SB_MAX_ITER=300
export V46_55_SB_TOLERANCE=0.0000001
export V46_55_SB_DAMPING=1.0
export V46_55_SB_DECODE_BEAM=128

# Production generation may fall back to legacy beam and records the reason.
export V46_55_SB_ALLOW_LEGACY_FALLBACK=1

# Strict paper evaluation must fail closed instead of mixing solvers.
# export V46_55_SB_ALLOW_LEGACY_FALLBACK=0

export V46_55_GRAPH_SO3_W=0.55
export V46_55_GRAPH_LORENTZ_W=0.15
export V46_55_GRAPH_POSTURE_HARD=2.0
export V46_55_GRAPH_FLOOR_HARD_M=0.20
export V46_55_GRAPH_CONTACT_HARD=0.75
export V46_55_GRAPH_ROOT_VEL_HARD_MPS=2.0
export V46_55_GRAPH_SO3_HARD_RAD=0.0
export V46_55_GRAPH_RESET_ACCENT=0.82

# SO(3) endpoints are created by events/intrinsic_geometry.py.
export V46_55_REQUIRE_SO3_EDGE=1
# Enable only after grounding.mixed_curvature embed has written Lorentz factors.
export V46_55_REQUIRE_LORENTZ_EDGE=0
