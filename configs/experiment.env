#!/usr/bin/env bash
# Generated authoritative research profile.

# ---- scheduler.env ----
# =============================================================================
# V46.51 Fresh-WAV Schedule Transaction + V46.50 Event Heading
# =============================================================================
# Source this file after entering the EDGE repository.  Scripts use the explicit
# edge Python path, so an accidentally active `(base)` shell cannot redirect
# training to the wrong interpreter.

_PROJECT_ROOT="${ROOT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
export EDGE_ROOT="$_PROJECT_ROOT"
export V46_51_PYTHON="${V46_51_PYTHON:-/home/disk/lsm/conda_envs/edge/bin/python}"
export PYTHONPATH="$_PROJECT_ROOT"
unset _PROJECT_ROOT
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"
export V46_DEVICE="${V46_DEVICE:-cuda}"
export V46_49_RETARGET_DEVICE="${V46_49_RETARGET_DEVICE:-cuda}"

# -----------------------------------------------------------------------------
# Formal V46.49.4 source-motion contract
# -----------------------------------------------------------------------------
export V46_49_NONROOT_POSITION_MODE=ignore
export V46_49_HEADING_MODE=stabilize
export V46_49_ROOT_ORIENTATION_LOCK=1
export V46_49_GRAVITY_HARD_FAIL=1
export V46_49_GRAVITY_TORSO_P05_MIN="${V46_49_GRAVITY_TORSO_P05_MIN:-0.43}"
export V46_49_FIT_RMSE_P95_MAX_M=0.18

# Validated V46.49.3b absolute heading settings.
export V46_49_HEADING_SMOOTH_SECONDS=0.35
export V46_49_HEADING_BASELINE_SECONDS=3.0
export V46_49_HEADING_MIN_DRIFT_DEG_S=3.5
export V46_49_HEADING_MIN_PERSIST_SECONDS=2.0
export V46_49_HEADING_SIGN_CONSISTENCY=0.72
export V46_49_HEADING_MAX_BASELINE_VARIATION_DEG_S=20.0
export V46_49_HEADING_MAX_CORRECTION_DEG_S=90.0

# Temporally stronger retargeting for local jitter, while retaining the same
# keypoint/gravity constraints.  These are retraining/rebuild settings.
export V46_49_RETARGET_FPS=30
export V46_49_RETARGET_CHUNK=256
export V46_49_RETARGET_OVERLAP=64
export V46_49_RETARGET_ITERS=120
export V46_49_RETARGET_LR=0.025
export V46_49_RETARGET_VEL_W=0.22
export V46_49_RETARGET_ACC_W=0.060
export V46_49_RETARGET_KEYPOINT_W=30.0
export V46_49_RETARGET_ROOT_W=8.0
export V46_49_RETARGET_UPRIGHT_W=5.0

# -----------------------------------------------------------------------------
# V46.50 event-heading DB contract
# -----------------------------------------------------------------------------
export V46_50_REQUIRE_V46_49_4_CACHE=1
export V46_50_DROP_RESET_OR_DRIFT=1
export V46_50_ENTRY_HEADING_MEDIAN_SECONDS=0.15
export V46_50_ENTRY_HEADING_P95_MAX_DEG=5.0
export V46_50_GLOBAL_MAX_EVENT_SECONDS=6.0
export V46_50_TURN_INTERVAL_SPEED_DEG_S=18.0
export V46_50_MIN_TURN_INTERVAL_SECONDS=0.40
export V46_50_TURN_EDGE_BOUNDARY_BONUS=0.45
export V46_50_CUT_THROUGH_TURN_PENALTY=0.55

export V46_50_BUDGET_POSE_CALM_DEG=30
export V46_50_BUDGET_INSTRUMENT_DEG=45
export V46_50_BUDGET_FOOTWORK_DEG=90
export V46_50_BUDGET_AERIAL_TRANSITION_DEG=120
export V46_50_BUDGET_DEFAULT_DEG=60
export V46_50_BUDGET_TURN_DEG=360
export V46_50_BUDGET_EXPLICIT_SPIN_DEG=540
export V46_50_NON_TURN_HARD_EXCESS_MULTIPLIER=1.50
export V46_50_RESET_MIN_SECONDS=1.5
export V46_50_RESET_BUDGET_MULTIPLIER=1.20
export V46_50_RESET_MONOTONICITY_MIN=0.62

# Planner-owned stage heading.
export V46_50_STAGE_INITIAL_HEADING_DEG=0
export V46_50_HEADING_TRIAL_TOPK=32
export V46_50_HEADING_PLANNER_WEIGHT=0.85
export V46_50_INTENT_MISMATCH_WEIGHT=1.0
export V46_50_STAGE_FRONT_ANCHOR_WEIGHT=1.25
export V46_50_CONSECUTIVE_TURN_PENALTY=0.75
export V46_50_HEADING_QUALITY_WEIGHT=0.75
export V46_50_PROTECT_PLANNED_ROOT_HEADING=1
export V46_50_PLANNED_HEADING_ERROR_P95_MAX_DEG=2.0

# Closed-loop boundary candidate budget.
export V46_46_CANDIDATE_TOPK=96
export V46_46_RESELECT_TOPK=64
export V46_46_RESELECT_ENABLE=1
export V46_46_MAX_RESELECT_ROUNDS=2
export V46_46_RISK_ADAPT_TRANSITION_ENABLE=1

# Strong-reference principle: real cultural event cores stay dominant.
export V46_REFINER_CORE_STRENGTH=0.02
export V46_DIFFUSION_CORE_STRENGTH=0.00
export V46_DIFFUSION_TRANSITION_STRENGTH=0.25
export V46_TRANSITION_BUDGET_ENABLE=1
export V46_TRANSITION_INBETWEEN_ENABLE=1
export V46_ENABLE_TRUE_IK=1
export V46_ENABLE_REFINER=1
export V46_ENABLE_DIFFUSION=1

# Strict MSSD semantics remain enabled inside the current V46 core. V46.51
# additionally verifies current-WAV provenance before delegation.
export V46_MSSD_ENABLE=1
export V46_MSSD_REQUIRE_FINAL_SCHEDULE_FOR_GENERATE=1
export V46_REQUIRE_PRETRAINED_ROUTER_SLOTS=1

# -----------------------------------------------------------------------------
# V46.51 Fresh-WAV Audio–Schedule Transaction
# -----------------------------------------------------------------------------
export V46_51_REQUIRE_FRESH_WAV_SCHEDULE=1
export V46_51_ALLOW_SCHEDULE_REUSE=0
export V46_51_MAX_FRAME_ERROR=2
export V46_51_MAX_SECONDS_ERROR=0.10
export V46_51_FPS=30

# Every WAV gets a new V21/V26/V23 schedule transaction.  No SLOTS_JSON input is
# used by the formal scripts.
export V46_51_FORCE_RESCHEDULE_EACH_GENERATION=1
export V46_51_UNIQUE_FEATURE_CACHE=1

# Current trained scheduler asset overrides.  Leave blank to use the resolver's
# fixed validated candidate paths.  The resolver never chooses arbitrary newest
# checkpoints.
export V46_51_INDEX_JSON="${V46_51_INDEX_JSON:-}"
export V46_51_DURATION_INDEX_NPZ="${V46_51_DURATION_INDEX_NPZ:-}"
export V46_51_ROUTER_CKPT="${V46_51_ROUTER_CKPT:-}"
export V46_51_PLANNER_CKPT="${V46_51_PLANNER_CKPT:-}"
export V46_51_V23_CKPT="${V46_51_V23_CKPT:-}"
export V46_51_HIERARCHY_INDEX_NPZ="${V46_51_HIERARCHY_INDEX_NPZ:-}"
export V46_51_START_POSE="${V46_51_START_POSE:-}"

# Music scheduling policy.
export V46_51_MIN_PHRASE_SECONDS="${V46_51_MIN_PHRASE_SECONDS:-2.5}"
export V46_51_MAX_PHRASE_SECONDS="${V46_51_MAX_PHRASE_SECONDS:-7.5}"
export V46_51_MAX_SINGLE_EVENT_SECONDS="${V46_51_MAX_SINGLE_EVENT_SECONDS:-3.20}"
export V46_51_CALM_MAX_SINGLE_EVENT_SECONDS="${V46_51_CALM_MAX_SINGLE_EVENT_SECONDS:-2.80}"
export V46_51_MIN_SUBPHRASE_SECONDS="${V46_51_MIN_SUBPHRASE_SECONDS:-1.60}"
export V46_51_MAX_EVENTS_PER_PHRASE="${V46_51_MAX_EVENTS_PER_PHRASE:-4}"
export V46_51_BOUNDARY_QUANTILE="${V46_51_BOUNDARY_QUANTILE:-0.68}"
export V46_51_BEAT_SNAP_SECONDS="${V46_51_BEAT_SNAP_SECONDS:-0.35}"
export V46_51_SLOT_BEAT_SNAP_SECONDS="${V46_51_SLOT_BEAT_SNAP_SECONDS:-0.25}"
export V46_51_MAX_PHRASES="${V46_51_MAX_PHRASES:-160}"
export V46_51_BEAM_SIZE="${V46_51_BEAM_SIZE:-24}"
export V46_51_CANDIDATE_TOP_K="${V46_51_CANDIDATE_TOP_K:-256}"
export V46_51_GRAPH_NODE_TOP_K="${V46_51_GRAPH_NODE_TOP_K:-96}"

# Deep music features are enabled when the local CLAP setup is available.  Set
# REQUIRE_DEEP_MUSIC=1 only after the checkpoint/model audit passes.
export V46_51_DEEP_MUSIC_FEATURES="${V46_51_DEEP_MUSIC_FEATURES:-1}"
export V46_51_REQUIRE_DEEP_MUSIC="${V46_51_REQUIRE_DEEP_MUSIC:-0}"
export V46_51_DEEP_MUSIC_MODEL="${V46_51_DEEP_MUSIC_MODEL:-clap}"
export V46_51_DEEP_MUSIC_MIN_SUCCESS="${V46_51_DEEP_MUSIC_MIN_SUCCESS:-0.80}"

# V26 transition diffusion can be enabled with an explicit checkpoint.
export V46_51_TRANSITION_DIFFUSION="${V46_51_TRANSITION_DIFFUSION:-0}"
export V46_51_TRANSITION_DIFFUSION_CKPT="${V46_51_TRANSITION_DIFFUSION_CKPT:-}"
export V46_51_TRANSITION_DIFFUSION_BLEND="${V46_51_TRANSITION_DIFFUSION_BLEND:-0.18}"
export V46_51_TRANSITION_DIFFUSION_STEPS="${V46_51_TRANSITION_DIFFUSION_STEPS:-32}"

# -----------------------------------------------------------------------------
# Research split: source-level split before model training
# -----------------------------------------------------------------------------
export V46_51_SPLIT_SEED="${V46_51_SPLIT_SEED:-20260712}"
export V46_51_TRAIN_RATIO="${V46_51_TRAIN_RATIO:-0.80}"
export V46_51_VAL_RATIO="${V46_51_VAL_RATIO:-0.10}"
export V46_51_TEST_RATIO="${V46_51_TEST_RATIO:-0.10}"

# paper: train-only DB; qualitative_demo: retrieve from all-change DB.
export V46_51_DB_MODE="${V46_51_DB_MODE:-paper_train_only}"

# -----------------------------------------------------------------------------
# Rebuild/retrain controls
# -----------------------------------------------------------------------------
export V46_51_REBUILD_RETARGET_CACHE="${V46_51_REBUILD_RETARGET_CACHE:-1}"
export V46_51_REBUILD_EVENT_DB="${V46_51_REBUILD_EVENT_DB:-1}"
export V46_51_RETRAIN_V44="${V46_51_RETRAIN_V44:-1}"
export V46_51_RETRAIN_V45="${V46_51_RETRAIN_V45:-1}"
export V46_51_RETRAIN_V46="${V46_51_RETRAIN_V46:-1}"

export V44_EPOCHS="${V44_EPOCHS:-120}"
export V45_STEPS="${V45_STEPS:-8000}"
export V46_STEPS="${V46_STEPS:-15000}"
export V46_DIFFUSION_STEPS="${V46_DIFFUSION_STEPS:-50}"

# V44 unpaired training pool.  test_music_bank is intentionally excluded.
export MUSIC_DIRS="${MUSIC_DIRS:-proxy_music data/v21_router_music_valid25}"

# -----------------------------------------------------------------------------
# Default local paths
# -----------------------------------------------------------------------------
export CHANGE_BVH_DIR="${CHANGE_BVH_DIR:-change}"
export AUDIO="${AUDIO:-test_music_bank/dunhuangwu2.wav}"
export CONFIG="${CONFIG:-configs/motion_model.json}"


# ---- anatomy.env ----
#!/usr/bin/env bash
# V46.53.1 compatibility bridge.
# The preserved V46.51 base launcher sources this file. Re-apply the authoritative
# research profile so legacy configuration files cannot silently restore obsolete
# source-level one-vote thresholds.
_V46_53_1_CFG_ROOT="${ROOT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
# shellcheck disable=SC1090
source "$_V46_53_1_CFG_ROOT/configs/research.env"
unset _V46_53_1_CFG_ROOT


# ---- geometry.env ----
