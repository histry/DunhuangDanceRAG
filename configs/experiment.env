# V46.53.1 compatibility bridge for the latest public V46.53 wrapper.
_V46_53_1_CFG_ROOT="${ROOT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
# shellcheck disable=SC1090
source "$_V46_53_1_CFG_ROOT/configs/research.env"
unset _V46_53_1_CFG_ROOT


# ---- research.env ----
#!/usr/bin/env bash
# V46.53.1 authoritative research profile.
# External overrides use the V46_53_1_* names shown below.

export V46_53_1_PROFILE_VERSION="v46_53_1_contract_repair_20260718"
export V46_53_1_EXPECTED_TRAIN_MUSIC="${V46_53_1_EXPECTED_TRAIN_MUSIC:-788}"

# ---------- full rebuild / retraining ----------
export V46_53_FULL_REBUILD="${V46_53_1_FULL_REBUILD:-1}"
export V46_51_REBUILD_RETARGET_CACHE="${V46_53_1_REBUILD_RETARGET_CACHE:-1}"
export V46_51_REBUILD_EVENT_DB="${V46_53_1_REBUILD_EVENT_DB:-1}"
export V46_51_RETRAIN_V44="${V46_53_1_RETRAIN_V44:-1}"
export V46_51_RETRAIN_V45="${V46_53_1_RETRAIN_V45:-1}"
export V46_51_RETRAIN_V46="${V46_53_1_RETRAIN_V46:-1}"
export V46_51_DB_MODE="${V46_53_1_DB_MODE:-paper_train_only}"

# ---------- exact source-disjoint split ----------
export V46_52_ALLOW_PARTIAL_RETARGET=1
export V46_52_HARD_RETARGET_GATE=1
export V46_52_ALLOW_UNSAFE_RESCUE=0
export V46_52_MIN_OK_SOURCES="${V46_53_1_MIN_OK_SOURCES:-8}"
export V46_51_SPLIT_SEED="${V46_53_1_SPLIT_SEED:-20260718}"
export V46_51_TRAIN_RATIO="${V46_53_1_TRAIN_RATIO:-0.67}"
export V46_51_VAL_RATIO="${V46_53_1_VAL_RATIO:-0.165}"
export V46_51_TEST_RATIO="${V46_53_1_TEST_RATIO:-0.165}"

# ---------- V46.53.1 source retargeter ----------
export V46_53_1_RETARGET_ITERS="${V46_53_1_RETARGET_ITERS:-280}"
export V46_53_1_RETARGET_LR="${V46_53_1_RETARGET_LR:-0.018}"
export V46_52_RETARGET_PROGRESS=1
export V46_52_RETARGET_PROGRESS_EVERY="${V46_52_RETARGET_PROGRESS_EVERY:-25}"
export V46_52_RETARGET_GRAD_CLIP="${V46_52_RETARGET_GRAD_CLIP:-1.5}"
export V46_52_KEYPOINT_W="${V46_53_1_KEYPOINT_W:-24.0}"
export V46_52_ROOT_W="${V46_53_1_ROOT_W:-8.0}"
export V46_52_ROOT_VEL_W="${V46_53_1_ROOT_VEL_W:-1.8}"
export V46_52_POSE_PRIOR_W="${V46_53_1_POSE_PRIOR_W:-0.08}"
export V46_53_1_ROOT_ANCHOR_W="${V46_53_1_ROOT_ANCHOR_W:-0.35}"
export V46_53_1_ROOT_YAW_ANCHOR_MULT="${V46_53_1_ROOT_YAW_ANCHOR_MULT:-4.0}"
export V46_53_1_SO3_VEL_W="${V46_53_1_SO3_VEL_W:-0.025}"
export V46_53_1_SO3_ACC_W="${V46_53_1_SO3_ACC_W:-0.00008}"
export V46_52_UPRIGHT_W="${V46_53_1_UPRIGHT_W:-4.0}"
export V46_52_HEAD_ORDER_W="${V46_53_1_HEAD_ORDER_W:-2.0}"
export V46_52_FEET_ORDER_W="${V46_53_1_FEET_ORDER_W:-1.5}"
export V46_52_FLOOR_W="${V46_53_1_FLOOR_W:-8.0}"

# Source gate: only catastrophic numerical/physical failures are rejected here.
export V46_52_SOURCE_NONFINITE_MAX=0
export V46_52_SOURCE_ROT_ORTHO_P95_MAX="${V46_52_SOURCE_ROT_ORTHO_P95_MAX:-0.0003}"
export V46_52_SOURCE_ROT_DET_P95_MAX="${V46_52_SOURCE_ROT_DET_P95_MAX:-0.0003}"
export V46_52_SOURCE_LOCAL_SEVERE_RATIO_MAX="${V46_53_1_SOURCE_LOCAL_SEVERE_RATIO_MAX:-0.012}"
export V46_52_SOURCE_SPINE_CUM_P95_MAX_DEG="${V46_52_SOURCE_SPINE_CUM_P95_MAX_DEG:-185.0}"
export V46_52_SOURCE_TORSO_RATIO_P01_MIN="${V46_52_SOURCE_TORSO_RATIO_P01_MIN:-0.34}"
export V46_52_SOURCE_NECK_RATIO_P01_MIN="${V46_52_SOURCE_NECK_RATIO_P01_MIN:-0.36}"
export V46_52_SOURCE_COLLISION_RATIO_MAX="${V46_52_SOURCE_COLLISION_RATIO_MAX:-0.08}"
export V46_52_SOURCE_ANATOMY_QUALITY_MIN="${V46_52_SOURCE_ANATOMY_QUALITY_MIN:-0.18}"
export V46_52_SOURCE_GRAVITY_TORSO_P05_MIN="${V46_52_SOURCE_GRAVITY_TORSO_P05_MIN:-0.30}"
export V46_52_SOURCE_GRAVITY_TORSO_MEDIAN_MIN="${V46_52_SOURCE_GRAVITY_TORSO_MEDIAN_MIN:-0.55}"
export V46_52_SOURCE_HEAD_ABOVE_RATIO_MIN="${V46_52_SOURCE_HEAD_ABOVE_RATIO_MIN:-0.85}"
export V46_52_SOURCE_FEET_BELOW_RATIO_MIN="${V46_52_SOURCE_FEET_BELOW_RATIO_MIN:-0.85}"
export V46_52_SOURCE_HORIZONTAL_BODY_RATIO_MAX="${V46_52_SOURCE_HORIZONTAL_BODY_RATIO_MAX:-0.20}"
export V46_52_FIT_RMSE_P95_MAX_M="${V46_52_FIT_RMSE_P95_MAX_M:-0.14}"
export V46_52_SOURCE_BONE_DRIFT_MAX="${V46_52_SOURCE_BONE_DRIFT_MAX:-0.0003}"

# ---------- posture-aware event gate ----------
export V46_52_FLOOR_REFERENCE_MODE="${V46_52_FLOOR_REFERENCE_MODE:-stage_zero}"
export V46_52_STAGE_FLOOR_Y_M="${V46_52_STAGE_FLOOR_Y_M:-0.0}"
# Joint-centre proxy, not foot-sole mesh penetration.
export V46_52_FOOT_PENETRATION_P01_MIN_M="${V46_52_FOOT_PENETRATION_P01_MIN_M:--0.08}"
export V46_52_EVENT_LOCAL_LIMIT_RATIO_MAX="${V46_52_EVENT_LOCAL_LIMIT_RATIO_MAX:-0.060}"
export V46_52_EVENT_LOCAL_SEVERE_RATIO_MAX="${V46_52_EVENT_LOCAL_SEVERE_RATIO_MAX:-0.006}"
export V46_52_EVENT_SPINE_CUM_P95_MAX_DEG="${V46_52_EVENT_SPINE_CUM_P95_MAX_DEG:-170.0}"
export V46_52_EVENT_TORSO_RATIO_P05_MIN="${V46_52_EVENT_TORSO_RATIO_P05_MIN:-0.46}"
export V46_52_EVENT_NECK_RATIO_P05_MIN="${V46_52_EVENT_NECK_RATIO_P05_MIN:-0.48}"
export V46_52_EVENT_COLLISION_RATIO_MAX="${V46_52_EVENT_COLLISION_RATIO_MAX:-0.05}"
export V46_52_EVENT_ANATOMY_HARD_QUALITY_MIN="${V46_52_EVENT_ANATOMY_HARD_QUALITY_MIN:-0.30}"
export V46_52_EVENT_QUALITY_MIN_STANDING="${V46_52_EVENT_QUALITY_MIN_STANDING:-0.46}"
export V46_52_EVENT_QUALITY_MIN_AERIAL="${V46_52_EVENT_QUALITY_MIN_AERIAL:-0.46}"
export V46_52_EVENT_QUALITY_MIN_HALF_SQUAT="${V46_52_EVENT_QUALITY_MIN_HALF_SQUAT:-0.44}"
export V46_52_EVENT_QUALITY_MIN_DEEP_SQUAT="${V46_52_EVENT_QUALITY_MIN_DEEP_SQUAT:-0.41}"
export V46_52_EVENT_QUALITY_MIN_KNEELING="${V46_52_EVENT_QUALITY_MIN_KNEELING:-0.38}"
export V46_52_EVENT_QUALITY_MIN_FLOOR_POSE="${V46_52_EVENT_QUALITY_MIN_FLOOR_POSE:-0.38}"
export V46_52_EVENT_RESCUE_QUALITY_FLOOR="${V46_52_EVENT_RESCUE_QUALITY_FLOOR:-0.30}"
export V46_52_EVENT_MIN_FRAMES="${V46_52_EVENT_MIN_FRAMES:-18}"
export V46_52_EVENT_MIN_PER_SOURCE_TRAIN="${V46_52_EVENT_MIN_PER_SOURCE_TRAIN:-4}"
export V46_52_EVENT_MIN_PER_SOURCE_EVAL="${V46_52_EVENT_MIN_PER_SOURCE_EVAL:-1}"
export V46_52_EVENT_DB_MIN_EVENTS_TRAIN="${V46_52_EVENT_DB_MIN_EVENTS_TRAIN:-64}"
export V46_52_EVENT_DB_MIN_EVENTS_EVAL="${V46_52_EVENT_DB_MIN_EVENTS_EVAL:-12}"
export V46_52_EVENT_DB_MIN_KEEP_RATIO="${V46_52_EVENT_DB_MIN_KEEP_RATIO:-0.35}"

# Anatomy losses preserve cultural asymmetry; symmetry is disabled by default.
export V46_52_LOSS_LOCAL_LIMIT_W="${V46_53_1_LOSS_LOCAL_LIMIT_W:-3.0}"
export V46_52_LOSS_LOCAL_SEVERE_W="${V46_53_1_LOSS_LOCAL_SEVERE_W:-5.0}"
export V46_52_LOSS_SPINE_W="${V46_53_1_LOSS_SPINE_W:-4.0}"
export V46_52_LOSS_TORSO_W="${V46_53_1_LOSS_TORSO_W:-4.5}"
export V46_52_LOSS_BEND_W="${V46_53_1_LOSS_BEND_W:-1.2}"
export V46_52_LOSS_COLLISION_W="${V46_53_1_LOSS_COLLISION_W:-2.5}"
export V46_52_LOSS_SYMMETRY_W="${V46_53_1_LOSS_SYMMETRY_W:-0.0}"

# ---------- final whole-song cultural-gravity contract ----------
# Allows legitimate bending/kneeling while still rejecting horizontal collapse.
export V46_49_GRAVITY_TORSO_P05_MIN="${V46_53_1_FINAL_TORSO_P05_MIN:-0.30}"
export V46_49_GRAVITY_TORSO_MEDIAN_MIN="${V46_53_1_FINAL_TORSO_MEDIAN_MIN:-0.60}"
export V46_49_HEAD_ABOVE_RATIO_MIN="${V46_53_1_FINAL_HEAD_ABOVE_RATIO_MIN:-0.90}"
export V46_49_FEET_BELOW_RATIO_MIN="${V46_53_1_FINAL_FEET_BELOW_RATIO_MIN:-0.88}"
export V46_49_HORIZONTAL_BODY_RATIO_MAX="${V46_53_1_FINAL_HORIZONTAL_RATIO_MAX:-0.15}"
export V46_52_GRAVITY_TORSO_P05_MIN="$V46_49_GRAVITY_TORSO_P05_MIN"
export V46_52_GRAVITY_TORSO_MEDIAN_MIN="$V46_49_GRAVITY_TORSO_MEDIAN_MIN"
export V46_52_HEAD_ABOVE_RATIO_MIN="$V46_49_HEAD_ABOVE_RATIO_MIN"
export V46_52_FEET_BELOW_RATIO_MIN="$V46_49_FEET_BELOW_RATIO_MIN"
export V46_52_HORIZONTAL_BODY_RATIO_MAX="$V46_49_HORIZONTAL_BODY_RATIO_MAX"

# ---------- V46.53 grounding / routing / local repair ----------
export V46_53_ENABLE=1
export V46_53_GROUNDER_ENABLE=1
export V46_53_TRAIN_GROUNDER_ON_BUILD=1
export V46_53_GROUNDER_STEPS="${V46_53_GROUNDER_STEPS:-1600}"
export V46_53_GROUNDER_BATCH="${V46_53_GROUNDER_BATCH:-128}"
export V46_53_GROUNDER_CUDA=1
export V46_53_GROUNDER_INFER_CUDA="${V46_53_GROUNDER_INFER_CUDA:-0}"
export V46_53_GLOBAL_ROUTE_ENABLE=1
export V46_53_GLOBAL_ROUTE_BEAM="${V46_53_GLOBAL_ROUTE_BEAM:-32}"
export V46_53_GLOBAL_ROUTE_TOPK="${V46_53_GLOBAL_ROUTE_TOPK:-20}"
export V46_53_GLOBAL_ROUTE_ENTROPY="${V46_53_GLOBAL_ROUTE_ENTROPY:-0.08}"
export V46_53_BODY_PART_MASK_ENABLE=1
export V46_53_FULL_ROLLBACK_ON_FAIL=1

# ---------- current-WAV semantics and duration ----------
export V46_51_DEEP_MUSIC_FEATURES=1
export V46_51_DEEP_MUSIC_MODEL="${V46_51_DEEP_MUSIC_MODEL:-clap}"
export V46_51_REQUIRE_DEEP_MUSIC="${V46_51_REQUIRE_DEEP_MUSIC:-1}"
export V46_51_DEEP_MUSIC_MIN_SUCCESS="${V46_51_DEEP_MUSIC_MIN_SUCCESS:-0.80}"
export V46_53_ENFORCE_DYNAMIC_DURATION=1
export V46_53_OUTPUT_FRAME_TOLERANCE="${V46_53_OUTPUT_FRAME_TOLERANCE:-2}"
unset V46_51_FIXED_DURATION_SECONDS || true
