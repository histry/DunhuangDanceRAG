export V46_52_EVENT_QUALITY_MIN_KNEELING="${V46_52_EVENT_QUALITY_MIN_KNEELING:-0.38}"
export V46_52_EVENT_QUALITY_MIN_FLOOR_POSE="${V46_52_EVENT_QUALITY_MIN_FLOOR_POSE:-0.38}"
export V46_52_EVENT_RESCUE_QUALITY_FLOOR="${V46_52_EVENT_RESCUE_QUALITY_FLOOR:-0.30}"
export V46_52_EVENT_MIN_FRAMES="${V46_52_EVENT_MIN_FRAMES:-18}"
export V46_52_EVENT_MIN_PER_SOURCE_TRAIN="${V46_52_EVENT_MIN_PER_SOURCE_TRAIN:-4}"
