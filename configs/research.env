export V46_49_FEET_BELOW_RATIO_MIN="${V46_53_1_FINAL_FEET_BELOW_RATIO_MIN:-0.88}"
export V46_49_HORIZONTAL_BODY_RATIO_MAX="${V46_53_1_FINAL_HORIZONTAL_RATIO_MAX:-0.15}"
export V46_52_GRAVITY_TORSO_P05_MIN="$V46_49_GRAVITY_TORSO_P05_MIN"
export V46_52_GRAVITY_TORSO_MEDIAN_MIN="$V46_49_GRAVITY_TORSO_MEDIAN_MIN"
export V46_52_HEAD_ABOVE_RATIO_MIN="$V46_49_HEAD_ABOVE_RATIO_MIN"
export V46_52_FEET_BELOW_RATIO_MIN="$V46_49_FEET_BELOW_RATIO_MIN"
export V46_52_HORIZONTAL_BODY_RATIO_MAX="$V46_49_HORIZONTAL_BODY_RATIO_MAX"

# ---------- V46.53 grounding / routing / local repair ----------
export V46_53_ENABLE=1
export V46_53_GROUNDER_ENABLE=1
export V46_53_TRAIN_GROUNDER_ON_BUILD=1
export V46_53_GROUNDER_STEPS="${V46_53_GROUNDER_STEPS:-1600}"
