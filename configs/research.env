#!/usr/bin/env bash
# V46.53.1 authoritative research profile.
# External overrides use the V46_53_1_* names shown below.

export V46_53_1_PROFILE_VERSION="v46_53_1_contract_repair_20260718"
export V46_53_1_EXPECTED_TRAIN_MUSIC="${V46_53_1_EXPECTED_TRAIN_MUSIC:-788}"

# ---------- full rebuild / retraining ----------
export V46_53_FULL_REBUILD="${V46_53_1_FULL_REBUILD:-1}"
