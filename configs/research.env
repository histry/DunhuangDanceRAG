export V46_52_SOURCE_FEET_BELOW_RATIO_MIN="${V46_52_SOURCE_FEET_BELOW_RATIO_MIN:-0.85}"
export V46_52_SOURCE_HORIZONTAL_BODY_RATIO_MAX="${V46_52_SOURCE_HORIZONTAL_BODY_RATIO_MAX:-0.20}"
export V46_52_FIT_RMSE_P95_MAX_M="${V46_52_FIT_RMSE_P95_MAX_M:-0.14}"
export V46_52_SOURCE_BONE_DRIFT_MAX="${V46_52_SOURCE_BONE_DRIFT_MAX:-0.0003}"

# ---------- posture-aware event gate ----------
export V46_52_FLOOR_REFERENCE_MODE="${V46_52_FLOOR_REFERENCE_MODE:-stage_zero}"
export V46_52_STAGE_FLOOR_Y_M="${V46_52_STAGE_FLOOR_Y_M:-0.0}"
# Joint-centre proxy, not foot-sole mesh penetration.
export V46_52_FOOT_PENETRATION_P01_MIN_M="${V46_52_FOOT_PENETRATION_P01_MIN_M:--0.08}"
export V46_52_EVENT_LOCAL_LIMIT_RATIO_MAX="${V46_52_EVENT_LOCAL_LIMIT_RATIO_MAX:-0.060}"
export V46_52_EVENT_LOCAL_SEVERE_RATIO_MAX="${V46_52_EVENT_LOCAL_SEVERE_RATIO_MAX:-0.006}"
export V46_52_EVENT_SPINE_CUM_P95_MAX_DEG="${V46_52_EVENT_SPINE_CUM_P95_MAX_DEG:-170.0}"
export V46_52_EVENT_TORSO_RATIO_P05_MIN="${V46_52_EVENT_TORSO_RATIO_P05_MIN:-0.46}"
export V46_52_EVENT_NECK_RATIO_P05_MIN="${V46_52_EVENT_NECK_RATIO_P05_MIN:-0.48}"
export V46_52_EVENT_COLLISION_RATIO_MAX="${V46_52_EVENT_COLLISION_RATIO_MAX:-0.05}"
