export V46_52_SOURCE_ANATOMY_QUALITY_MIN="${V46_52_SOURCE_ANATOMY_QUALITY_MIN:-0.18}"
export V46_52_SOURCE_GRAVITY_TORSO_P05_MIN="${V46_52_SOURCE_GRAVITY_TORSO_P05_MIN:-0.30}"
