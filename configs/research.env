export V46_54_ROUTER_BATCH="${V46_54_ROUTER_BATCH:-256}"
export V46_54_DURATION_AUGMENTATIONS="${V46_54_DURATION_AUGMENTATIONS:-4}"
export V46_54_DURATION_EPOCHS="${V46_54_DURATION_EPOCHS:-240}"
