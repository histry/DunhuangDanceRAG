#!/usr/bin/env bash
# Public, version-free project paths. Historical environment names below are
# compatibility aliases consumed by the frozen research implementation.
export PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PYTHON_BIN="/home/disk/lsm/conda_envs/edge/bin/python3.9"
export TRAIN_MUSIC_DIR="$PROJECT_ROOT/assets/music/train"
export CLASSICAL_EVAL_DIR="$PROJECT_ROOT/assets/music/classical_eval"
export TEST_AUDIO="$PROJECT_ROOT/assets/music/test/audio/dunhuangwu2.wav"
export BVH_DATASET_DIR="$PROJECT_ROOT/assets/motion/bvh"
export MUSIC_ROUTER_WEIGHT="$PROJECT_ROOT/assets/weights/music/router.pt"
export MUSIC_PLANNER_WEIGHT="$PROJECT_ROOT/assets/weights/music/planner.pt"
export DURATION_MODEL_WEIGHT="$PROJECT_ROOT/assets/weights/music/duration.pt"
export EVENT_INDEX="$PROJECT_ROOT/assets/indexes/event_index.json"
export DURATION_INDEX="$PROJECT_ROOT/assets/indexes/duration_index.npz"
export HIERARCHY_INDEX="$PROJECT_ROOT/assets/indexes/hierarchy_index.npz"
export START_POSE="$PROJECT_ROOT/assets/indexes/start_pose.npy"

# Runtime compatibility aliases.
export ROOT_DIR="$PROJECT_ROOT"
export V46_51_PYTHON="$PYTHON_BIN"
export CHANGE_BVH_DIR="$BVH_DATASET_DIR"
export MUSIC_DIRS="$TRAIN_MUSIC_DIR"
export AUDIO="$TEST_AUDIO"
export V46_51_ROUTER_CKPT="$MUSIC_ROUTER_WEIGHT"
export V46_51_PLANNER_CKPT="$MUSIC_PLANNER_WEIGHT"
export V46_51_V23_CKPT="$DURATION_MODEL_WEIGHT"
export V46_51_INDEX_JSON="$EVENT_INDEX"
export V46_51_DURATION_INDEX_NPZ="$DURATION_INDEX"
[[ -s "$HIERARCHY_INDEX" ]] && export V46_51_HIERARCHY_INDEX_NPZ="$HIERARCHY_INDEX" || true
[[ -s "$START_POSE" ]] && export V46_51_START_POSE="$START_POSE" || true
export V46_53_1_ALLOW_SOFT_ROOT_CONTRACT=1
