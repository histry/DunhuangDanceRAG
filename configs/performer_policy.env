# Whole-song performer-group policy.
# auto: choose one group once, then keep it fixed for the complete song.
# female / male: explicit fixed group.
# mixed: explicit mixed-source experiment with switch penalties.
export PERFORMER_GROUP="${PERFORMER_GROUP:-auto}"
export PERFORMER_ALLOW_CROSS_GROUP_RESCUE="${PERFORMER_ALLOW_CROSS_GROUP_RESCUE:-0}"
export PERFORMER_FIXED_GROUP_SWITCH_PENALTY="${PERFORMER_FIXED_GROUP_SWITCH_PENALTY:-1000000}"
export PERFORMER_MIXED_SWITCH_PENALTY="${PERFORMER_MIXED_SWITCH_PENALTY:-2.0}"
